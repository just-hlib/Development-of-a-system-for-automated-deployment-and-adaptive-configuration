{
  "persona": "gamer",
  "discord": {
    "theme": "dark",
    "fontSize": 16,
    "messageDisplayCompact": false,
    "showCurrentGame": true,
    "enableQualityOfLifeFeatures": true,
    "hardware_acceleration": true,
    "open_on_startup": true,
    "minimize_to_tray": true
